#!/bin/sh

dependencies="
\tzsh\n
\tcurl\n
\twget\n
\tunzip\n
\tgit\n
\tpip (for python 3)\n
"

nodejs_lts_latest='18.12.1'

exit_program() {
    case "$1" in
        2)
            echo "$2 is required for bootstrap to work. Here are the dependencies required for bootstrap:"
            echo $dependencies
            ;;
        *)
            echo "invalid exit code: $1"
    esac
    
    echo 'If you are able to, please run ~/.config/yadm/bootstrap once you have finished fixing your errors'
    exit 1
}

# from https://raw.github.com/ohmyzsh/ohmyzsh/master/tools/install.sh
command_exists() {
  command -v "$1" >/dev/null 2>&1
}

# make sure that all dependencies are installed
command_exists git || exit_program 2 git
command_exists zsh || exit_program 2 zsh
command_exists pip || exit_program 2 pip
command_exists curl || exit_program 2 curl
command_exists wget || exit_program 2 wget
command_exists unzip || exit_program 2 unzip

# starship prompt for bash & other shells 😊
curl -sS https://starship.rs/install.sh | sh

# install fnm and the latest lts release
curl -fsSL https://fnm.vercel.app/install | bash
fnm install nodejs_lts_latest 

# install pyenv and pipenv
curl https://pyenv.run | sh
pip install pipenv

# install oh-my-zsh
wget https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh
sh install.sh --keep-zshrc
rm install.sh

echo "You're almost done setting up! Just a couple more housekeeping items:"
echo "Please install these oh-my-zsh dependencies  😊"
echo 'git clone https://github.com/zsh-users/zsh-autosuggestions ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-autosuggestions'
echo 'git clone https://github.com/zsh-users/zsh-syntax-highlighting.git ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting'
echo 'git clone --depth=1 https://github.com/romkatv/powerlevel10k.git ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/powerlevel10k'
echo 'pip install thefuck'

